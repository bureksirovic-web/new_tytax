# Your Supabase project URL (e.g., https://your-project.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase public anonymous key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your Supabase service role key (keep this secret, do not expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# The URL where your app is hosted (e.g., http://localhost:3000 for local development)
NEXT_PUBLIC_APP_URL=
